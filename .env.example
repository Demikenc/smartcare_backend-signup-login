# Copy this file to .env and fill in your real values.
# Get these from: Supabase Dashboard → Settings → API
#
# VITE_SUPABASE_URL is your Project URL (e.g. https://abcxyz.supabase.co)
# VITE_SUPABASE_ANON_KEY is the "anon public" key — NOT the service_role key.
# The anon key is safe to expose in client-side code; RLS policies
# protect your data even though this key is public.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Paystack public key — found at: Paystack Dashboard → Settings → API Keys & Webhooks
# Use the TEST key (pk_test_...) while developing, LIVE key (pk_live_...) in production.
# This is a PUBLIC key — safe to expose in client-side code. Never put your
# Paystack SECRET key here; that belongs only in your n8n webhook handler.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
